<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="enrol/courseapproval/db" VERSION="20260211" COMMENT="XMLDB file for Moodle enrol/courseapproval">
    <TABLES>
        <TABLE NAME="enrol_courseapproval_pending" COMMENT="Stores users who completed Course A but Course B has not started yet.">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
                <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="The destination Course B ID"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="The user waiting to be enrolled"/>
                <FIELD NAME="enrolid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="The enrolment instance ID in Course B"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Timestamp when the completion was detected"/>
            </FIELDS>
            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
                <KEY NAME="fk_courseid" TYPE="foreign" FIELDS="courseid" REFTABLE="course" REFFIELDS="id"/>
                <KEY NAME="fk_userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
                <KEY NAME="fk_enrolid" TYPE="foreign" FIELDS="enrolid" REFTABLE="enrol" REFFIELDS="id"/>
            </KEYS>
            <INDEXES>
                <INDEX NAME="courseid_userid" UNIQUE="true" FIELDS="courseid, userid"/>
            </INDEXES>
        </TABLE>
    </TABLES>
</XMLDB>
